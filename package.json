{
  "name": "auth-server",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "ts-node ./src/index.ts | pino-pretty --singleLine -o \"{req.method} {req.url} {res.statusCode} {msg}\"",
    "lint": "tsc --noEmit && eslint .",
    "build": "tsc",
    "start": "node ./dist | pino-pretty --singleLine -o \"{req.method} {req.url} {res.statusCode} {msg}\"",
    "migrate": "node ./dist/migrateDb.js | pino-pretty"
  },
  "dependencies": {
    "@vscode/sqlite3": "5.1.12-vscode",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "nanoid": "^5.1.11",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
